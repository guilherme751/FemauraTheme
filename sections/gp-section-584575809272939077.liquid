    <title>Estatísticas Combinadas - Formato Barra</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #ffe6e8 0%, #f8d7da 100%);
            padding: 30px 20px;
            min-height: 100vh;
        }

        .stats-container {
            display: flex;
            flex-direction: column;
            gap: 20px;
            max-width: 650px;
            margin: 0 auto;
        }

        .stat-bar {
            display: flex;
            align-items: center;
            background: linear-gradient(90deg, #e04760, #f06780);
            border-radius: 50px;
            box-shadow: 0 8px 25px rgba(224, 71, 96, 0.3);
            overflow: hidden;
            position: relative;
            min-height: 70px;
            opacity: 0;
            transform: translateY(30px);
            animation: slideUp 0.8s ease-out forwards;
        }

        .stat-bar:nth-child(1) { animation-delay: 0.1s; }
        .stat-bar:nth-child(2) { animation-delay: 0.2s; }
        .stat-bar:nth-child(3) { animation-delay: 0.3s; }
        .stat-bar:nth-child(4) { animation-delay: 0.4s; }
        .stat-bar:nth-child(5) { animation-delay: 0.5s; }
        .stat-bar:nth-child(6) { animation-delay: 0.6s; }

        .stat-content {
            display: flex;
            align-items: center;
            gap: 20px;
            padding: 15px 25px;
            width: 100%;
            position: relative;
            z-index: 2;
        }

        .percentage {
            font-size: 1.8rem;
            font-weight: bold;
            color: white;
            text-shadow: 0 2px 4px rgba(0,0,0,0.2);
            min-width: 60px;
        }

        .stat-text {
            font-size: 1.3rem;
            color: white;
            font-weight: 500;
            flex: 1;
            text-shadow: 0 2px 4px rgba(0,0,0,0.2);
            line-height: 1.3;
        }

        .progress-bg {
            position: absolute;
            right: 0;
            top: 0;
            height: 100%;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50px;
            transition: width 1.5s ease-out;
        }

        /* Individual progress widths based on percentages */
        .stat-bar:nth-child(1) .progress-bg { width: 10%; animation: fillProgress1 2s ease-out 0.5s forwards; }
        .stat-bar:nth-child(2) .progress-bg { width: 7%; animation: fillProgress2 2s ease-out 0.7s forwards; }
        .stat-bar:nth-child(3) .progress-bg { width: 12%; animation: fillProgress3 2s ease-out 0.9s forwards; }
        .stat-bar:nth-child(4) .progress-bg { width: 7%; animation: fillProgress4 2s ease-out 1.1s forwards; }
        .stat-bar:nth-child(5) .progress-bg { width: 11%; animation: fillProgress5 2s ease-out 1.3s forwards; }
        .stat-bar:nth-child(6) .progress-bg { width: 9%; animation: fillProgress6 2s ease-out 1.5s forwards; }

        @keyframes slideUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fillProgress1 { from { width: 100%; } to { width: 10%; } }
        @keyframes fillProgress2 { from { width: 100%; } to { width: 15%; } }
        @keyframes fillProgress3 { from { width: 100%; } to { width: 12%; } }
        @keyframes fillProgress4 { from { width: 100%; } to { width: 7%; } }
        @keyframes fillProgress5 { from { width: 100%; } to { width: 11%; } }
        @keyframes fillProgress6 { from { width: 100%; } to { width: 9%; } }

        @media (max-width: 768px) {
            body {
                padding: 20px 15px;
            }

            .stats-container {
                max-width: 100%;
                gap: 15px;
            }

            .stat-bar {
                min-height: 60px;
            }

            .stat-content {
                gap: 15px;
                padding: 12px 20px;
            }

            .percentage {
                font-size: 1.5rem;
                min-width: 50px;
            }

            .stat-text {
                font-size: 1.1rem;
            }
        }

        @media (max-width: 480px) {
            .stat-content {
                gap: 12px;
                padding: 10px 15px;
            }

            .percentage {
                font-size: 1.3rem;
                min-width: 45px;
            }

            .stat-text {
                font-size: 1rem;
            }
        }
    </style>
</head>
