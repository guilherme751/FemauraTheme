    <!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stats Section</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #ddbbb2;
            font-family: sans-serif;
            padding: 30px 16px;
        }

        .stats-container {
            max-width: 95%;
            margin: 0 auto;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.95);
            padding: 28px 24px 24px;
            border-radius: 12px;
            box-shadow: 0 3px 15px rgba(76, 9, 9, 0.08);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            margin-bottom: 2;
        }

        .stat-card:last-child {
            margin-bottom: 0;
        }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 25px rgba(224, 71, 96, 0.15);
        }

        .percentage {
            font-size: 52px;
            font-weight: 700;
            color: #e04760;
            margin-bottom: 2px;
            line-height: 1;
        }

        .stat-description {
            color: #4C0909;
            font-size: 16px;
            line-height: 1.4;
            margin-bottom: 2px;
            font-weight: 500;
        }

        .progress-bar-container {
            width: 100%;
            height: 6px;
            background: rgba(224, 71, 96, 0.15);
            border-radius: 10px;
            overflow: hidden;
            position: relative;
        }

        .progress-bar {
            height: 100%;
            background: linear-gradient(90deg, #e04760 0%, #e04760 100%);
            border-radius: 10px;
            transition: width 1.5s cubic-bezier(0.65, 0, 0.35, 1);
            width: 0;
            display: block !important;
        }

        .stat-card.animate .progress-bar {
            width: var(--progress);
        }

        @media (max-width: 480px) {
            body {
                padding: 20px 12px;
            }

            .stat-card {
                padding: 24px 20px 20px;
                margin-bottom: 10px;
            }

            .percentage {
                font-size: 30px;
            }

            .stat-description {
                font-size: 20;
                margin-bottom: 2px;
            }
        }
    </style>
</head>
<body>
    <div class="stats-container">
        <div class="stat-card" data-progress="91">
            <div class="percentage">91%</div>
            <div class="stat-description">Relataram aumento da libido</div>
            <div class="progress-bar-container">
                <div class="progress-bar" style="--progress: 91%"></div>
            </div>
        </div>

        <div class="stat-card" data-progress="89">
            <div class="percentage">89%</div>
            <div class="stat-description">Observaram melhora na capacidade de excitação</div>
            <div class="progress-bar-container">
                <div class="progress-bar" style="--progress: 89%"></div>
            </div>
        </div>

        <div class="stat-card" data-progress="93">
            <div class="percentage">93%</div>
            <div class="stat-description">Melhoraram qualidade das relações íntimas</div>
            <div class="progress-bar-container">
                <div class="progress-bar" style="--progress: 93%"></div>
            </div>
        </div>
    </div>

    <script>
        // Animate progress bars on load
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('animate');
                }
            });
        }, { threshold: 0.5 });

        document.querySelectorAll('.stat-card').forEach(card => {
            observer.observe(card);
        });

        // Trigger animation on page load
        setTimeout(() => {
            document.querySelectorAll('.stat-card').forEach(card => {
