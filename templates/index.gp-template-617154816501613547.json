        "gg8B9ZP_O7U_text": "POR QUE COM O TESTO BOOST SERÁ DIFERENTE?",
        "ggQNmAXyaN-_label": "<p><span style=\"font-size:25px;\"><strong>COMPRAR AGORA</strong></span></p>",
        "ggkvMrIPJP0_childItem_0": "<p><strong>Somos o único </strong>no Brasil focado para a <strong>Testosterona Livre</strong>, a chave da libido feminina.</p>",
        "ggkvMrIPJP0_childItem_1": "<p>Nosso produto é<strong> 100% Natural</strong>, Zero efeitos Colaterais e Zero Riscos. Resultados reais com total segurança!</p>",
        "ggkvMrIPJP0_childItem_2": "<p><strong>Atua na Causa</strong>. Transformação de dentro para Fora. Reequilibra seu sistema hormonal.</p>",
        "ggmcKVsvD4V_label": "<p>GARANTIR MEU TESTO BOOST</p>",
